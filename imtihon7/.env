# 1. Django Asosiy Sozlamalari
# ------------------------------------------
# Xavfsizlik kaliti (Juda murakkab matn bo'lishi shart, bo'sh joylarsiz)
DJANGO_SECRET_KEY=*-go+wvc&z=(dt_5+j24b3wr&i&wcudh(o(@5+7%dl@iwo_v0$

# Debug rejimi. Serverda (Production) ALBATTA "false" bo'lishi shart!
