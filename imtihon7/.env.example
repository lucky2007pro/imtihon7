# ==========================================
# LOYIHA SERVER MUHITI (Environment Variables)
# ==========================================
# Ushbu faylni serverda `.env` nomiga o'zgartiring va o'z ma'lumotlaringizni kiriting!

# 1. Django Asosiy Sozlamalari
# ------------------------------------------
# Xavfsizlik kaliti (Juda murakkab matn bo'lishi shart, bo'sh joylarsiz)
DJANGO_SECRET_KEY=bepul-kutubxona-uchun-maxfiy-kalit-yozing-bu-yerga

# Debug rejimi. Serverda (Production) ALBATTA "false" bo'lishi shart!
DJANGO_DEBUG=false

# Ruxsat etilgan domenlar. Domeningiz yo'qligi uchun localhost va barcha IP larni ruxsat etamiz.
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,*

# 2. CORS va API Sozlamalari
# ------------------------------------------
# Frontend dasturingiz ishlaydigan IP manzilni ko'rsating.
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

# 3. Email (Pochta) Sozlamalari (Tasdiqlash kodlari uchun)
# ------------------------------------------
# Eslatma: Gmail ishlatmoqchi bo'lsangiz, Google hisobingizga kirib:
# Security -> 2-Step Verification -> App Passwords bo'limidan maxsus parol yaratib oling!
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=sizning.pochtangiz@gmail.com
EMAIL_HOST_PASSWORD=bu_yerga_google_app_parolini_yozing
DEFAULT_FROM_EMAIL=Kutubxona Tizimi <sizning.pochtangiz@gmail.com>

# 4. Sun'iy Intellekt (Gemini AI)
# ------------------------------------------
# Kutubxona maslahatchisi uchun (ixtiyoriy)
GEMINI_API_KEY=bu_yerga_api_kalit_yozing
GEMINI_MODEL=gemini-2.5-flash

# 5. Sayt Manzili
# ------------------------------------------
# Emailda boruvchi havolalar qaysi manzilga yo'naltirishini belgilaydi.
SITE_URL=http://127.0.0.1:8000
